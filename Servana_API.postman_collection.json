              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dept_name\": \"Sales & Marketing\",\n  \"dept_updated_by\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/departments/:id",
              "host": ["{{base_url}}"],
              "path": ["departments", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Get Department Members",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/departments/:id/members",
              "host": ["{{base_url}}"],
              "path": ["departments", ":id", "members"],
              "variable": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    },
    {
