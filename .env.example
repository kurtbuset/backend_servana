# for local development
REACT_SUPABASE_URL=http://localhost:8000

# for supabase docker development
# REACT_SUPABASE_URL=http://supabase-kong:8000
REACT_SERVICE_ROLE_KEY=your_service_role_key


# Server Configuration
PORT=5000


# Frontend URLs for CORS configuration
REACT_WEB_URL=http://localhost:3000
REACT_WEB_PRODUCTION_URL=http://frontend:3000


# JWT Secret for authentication
JWT_ACCESS_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here


# App Environment
NODE_ENV=development


# redis configuration
REDIS_HOST=redis
REDIS_PORT=6379

# For Render deployment
# REDIS_URL=redis://default:<password>@<host>:6379


# semaphore configuration
SEMAPHORE_SENDER_NAME=SERVANA
SEMAPHORE_API_KEY=your_sms_to_api_key_here


# vapid configuration
VAPID_MAILTO=mailto:admin@yourdomain.com
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

